# ──────────────────────────────────────────────
# API 配置 (必填)
# ──────────────────────────────────────────────
# API 密钥（优先使用 API_KEY，也可使用 DEEPSEEK_API_KEY 兼容旧配置）
API_KEY=sk-xxxxxxxxxxxxxxxx

# API 基础 URL（可选，兼容任意 OpenAI 兼容接口）
# 默认 DeepSeek: https://api.deepseek.com/v1
# 也可用于其他兼容服务，如 OpenAI / 本地模型 / 代理等
# API_BASE=https://api.deepseek.com/v1

# 文本模型名称（可选，不设置则留空）
TEXT_MODEL=deepseek-v4-flash

# 视觉模型名称（可选，不设置则留空）
VISION_MODEL=deepseek-vl2

# ──────────────────────────────────────────────
# 请求配置
# ──────────────────────────────────────────────
# 最大重试次数（可选，默认 3）
# MAX_RETRIES=3

# 请求超时秒数（可选，默认 60.0）
# REQUEST_TIMEOUT=60.0

# ──────────────────────────────────────────────
# Prompt 配置
# ──────────────────────────────────────────────
# 文本摘要 Prompt（可选）
# SUMMARY_PROMPT=你是一个专业的技术文章摘要助手。请用中文对以下微信公众号文章进行摘要，突出核心技术要点、关键信息与结论。控制在 300 字以内，以段落形式输出。

# 图片分析 Prompt（可选）
# IMAGE_ANALYSIS_PROMPT=请结合提供的上下文分析此图片的内容与技术含义。用中文简要描述图片中的关键信息，并说明其与上下文的关系。

# ──────────────────────────────────────────────
# 浏览器配置
# ──────────────────────────────────────────────
# 自定义 User-Agent（可选，默认为 iPhone Safari）
# USER_AGENT=Mozilla/5.0 (iPhone; CPU iPhone OS 16_0 like Mac OS X) AppleWebKit/605.1.15 (KHTML, like Gecko) Version/16.0 Mobile/15E148 Safari/604.1

# ──────────────────────────────────────────────
# 兼容旧版变量名 (可选，API_KEY 等新名称优先)
# ──────────────────────────────────────────────
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx
